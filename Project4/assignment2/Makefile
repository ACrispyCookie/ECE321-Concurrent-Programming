TARGET_DIR = ./target
MYTHREADS_SRC = ./src/mythreads.c
MYTHREADS_HEADER = ./src/mythreads.h
LIBMYCOROUTINES_DIR = ../assignment1/target
LIBMYCOROUTINES = $(LIBMYCOROUTINES_DIR)/mycoroutines.o

MYTHREADS_OBJ = $(TARGET_DIR)/mythreads.o
LIBMYTHREADS = $(TARGET_DIR)/libmythreads.a

all: $(LIBMYTHREADS) $(LIBMYCOROUTINES)

clear: $(MYTHREADS_OBJ) $(LIBMYTHREADS)
	rm -rf $(MYTHREADS_OBJ) $(LIBMYTHREADS)

$(LIBMYTHREADS): $(MYTHREADS_OBJ) $(LIBMYCOROUTINES)
	ar rcs $(LIBMYTHREADS) $(MYTHREADS_OBJ) $(LIBMYCOROUTINES)

$(MYTHREADS_OBJ): $(MYTHREADS_SRC) $(MYTHREADS_HEADER)
	gcc -Wall -g -c $(MYTHREADS_SRC) -o $(MYTHREADS_OBJ)