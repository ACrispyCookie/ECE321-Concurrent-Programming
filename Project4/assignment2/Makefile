TARGET_DIR = ./target
TEST_SRC = ./tests/test_mythr.c
MYTHREADS_SRC = ./src/mythreads.c
MYTHREADS_HEADER = ./src/mythreads.h
LIBMYCOROUTINES_DIR = ../assignment1/target
LIBMYCOROUTINES = $(LIBMYCOROUTINES_DIR)/mycoroutines.o

TEST = $(TARGET_DIR)/test_mythr
TEST_OBJ = $(TARGET_DIR)/test_mythr.o
MYTHREADS_OBJ = $(TARGET_DIR)/mythreads.o
LIBMYTHREADS = $(TARGET_DIR)/libmythreads.a

all: $(TEST) $(LIBMYTHREADS) $(LIBMYCOROUTINES)

clear: $(TEST) $(TEST_OBJ) $(MYTHREADS_OBJ) $(LIBMYTHREADS)
	rm -rf $(TEST) $(TEST_OBJ) $(MYTHREADS_OBJ) $(LIBMYTHREADS)

$(TEST): $(TEST_OBJ) $(MYTHREADS_OBJ) $(LIBMYTHREADS)
	gcc -Wall -g $(TEST_OBJ) $(MYTHREADS_OBJ) -L$(TARGET_DIR) -lmythreads -o $(TEST)

$(TEST_OBJ): $(TEST_SRC) $(MYTHREADS_HEADER)
	gcc -Wall -g -c $(TEST_SRC) -o $(TEST_OBJ)

$(LIBMYTHREADS): $(MYTHREADS_OBJ) $(LIBMYCOROUTINES)
	ar rcs $(LIBMYTHREADS) $(MYTHREADS_OBJ) $(LIBMYCOROUTINES)

$(MYTHREADS_OBJ): $(MYTHREADS_SRC) $(MYTHREADS_HEADER)
	gcc -Wall -g -c $(MYTHREADS_SRC) -o $(MYTHREADS_OBJ)