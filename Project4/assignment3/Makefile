TARGET_DIR = ./target
MYTHREADS_SRC = ./src/mythreads.c
MYTHREADS_HEADER = ./src/mythreads.h
MYTHREADS_OBJ = $(TARGET_DIR)/mythreads.o
LIBMYTHREADS = $(TARGET_DIR)/libmythreads.a

MYCOROUTINES_DIR = ../assignment1/target
MYCOROUTINES_OBJ = $(MYCOROUTINES_DIR)/mycoroutines.o

LIST_DIR = ../list/target
LIST_OBJ = $(LIST_DIR)/list.o

all: $(LIBMYTHREADS) $(MYCOROUTINES_OBJ) $(LIST_OBJ)

clear: $(MYTHREADS_OBJ) $(LIBMYTHREADS) 
	rm -rf $(MYTHREADS_OBJ) $(LIBMYTHREADS)

$(LIBMYTHREADS): $(MYTHREADS_OBJ) $(MYCOROUTINES_OBJ) $(LIST_OBJ)
	ar rcs $(LIBMYTHREADS) $(MYTHREADS_OBJ) $(MYCOROUTINES_OBJ) $(LIST_OBJ)

$(MYTHREADS_OBJ): $(MYTHREADS_SRC) $(MYTHREADS_HEADER)
	gcc -Wall -g -c $(MYTHREADS_SRC) -o $(MYTHREADS_OBJ)