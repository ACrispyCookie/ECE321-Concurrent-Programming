TARGET_DIR = ./target
TEST_SRC = ./tests/test_mycoroutines.c
MYCOROUTINES_SRC = ./src/mycoroutines.c
MYCOROUTINES_HEADER = ./src/mycoroutines.h

MYCOROUTINES_OBJ = $(TARGET_DIR)/mycoroutines.o
MYCOROUTINES_TEST_OBJ = $(TARGET_DIR)/test_mycoroutines.o
MYCOROUTINES_TEST = $(TARGET_DIR)/test_mycoroutines

all: $(MYCOROUTINES_TEST) $(MYCOROUTINES_OBJ)

clear: $(MYCOROUTINES_OBJ)
	rm -rf $(MYCOROUTINES_OBJ)

$(MYCOROUTINES_TEST): $(MYCOROUTINES_TEST_OBJ) $(MYCOROUTINES_OBJ)
	gcc -Wall -g $(MYCOROUTINES_TEST_OBJ) $(MYCOROUTINES_OBJ) -o $(MYCOROUTINES_TEST)

$(MYCOROUTINES_TEST_OBJ): $(TEST_SRC) $(MYCOROUTINES_HEADER)
	gcc -Wall -g -c $(TEST_SRC) -o $(MYCOROUTINES_TEST_OBJ)

$(MYCOROUTINES_OBJ): $(MYCOROUTINES_SRC) $(MYCOROUTINES_HEADER)
	gcc -Wall -g -c $(MYCOROUTINES_SRC) -o $(MYCOROUTINES_OBJ)