TARGET_DIR = ./target

MYCOROUTINES_SRC = ./src/mycoroutines.c
MYCOROUTINES_HEADER = ./src/mycoroutines.h
MYCOROUTINES_OBJ = $(TARGET_DIR)/mycoroutines.o

PIPES_SRC = ./tests/pipes.c
PIPES_HEADER = ./tests/pipes.h
PIPES_OBJ = $(TARGET_DIR)/pipes.o

MYCOROUTINES_TEST_SRC = ./tests/test_mycoroutines.c
MYCOROUTINES_TEST_OBJ = $(TARGET_DIR)/test_mycoroutines.o
MYCOROUTINES_TEST = $(TARGET_DIR)/test_mycoroutines

all: $(MYCOROUTINES_TEST)

clear_resources: 
	rm -rf ./resources/*.copy ./resources/*.copy2

clear: $(MYCOROUTINES_OBJ) $(MYCOROUTINES_TEST) $(MYCOROUTINES_TEST_OBJ) $(PIPES_OBJ)
	rm -rf $(MYCOROUTINES_OBJ) $(MYCOROUTINES_TEST) $(MYCOROUTINES_TEST_OBJ) $(PIPES_OBJ)

$(MYCOROUTINES_TEST): $(MYCOROUTINES_TEST_OBJ) $(MYCOROUTINES_OBJ) $(PIPES_OBJ)
	gcc -Wall -g $(MYCOROUTINES_TEST_OBJ) $(MYCOROUTINES_OBJ) $(PIPES_OBJ) -o $(MYCOROUTINES_TEST)

$(MYCOROUTINES_TEST_OBJ): $(MYCOROUTINES_TEST_SRC) $(MYCOROUTINES_HEADER)
	gcc -Wall -g -c $(MYCOROUTINES_TEST_SRC) -o $(MYCOROUTINES_TEST_OBJ)

$(PIPES_OBJ): $(PIPES_SRC) $(PIPES_HEADER)
	gcc -Wall -g -c $(PIPES_SRC) -o $(PIPES_OBJ)

$(MYCOROUTINES_OBJ): $(MYCOROUTINES_SRC) $(MYCOROUTINES_HEADER)
	gcc -Wall -g -c $(MYCOROUTINES_SRC) -o $(MYCOROUTINES_OBJ)